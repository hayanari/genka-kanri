# ================================================================
# 環境変数サンプル（無料枠で運用する想定）
# コピーして .env.local に貼るか、Vercel Environment Variables に設定
# ================================================================

# --- 必須 ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- 日次 Cron（必須・無料） ---
# Vercel に設定すると Cron が自動で Authorization: Bearer を付与します
CRON_SECRET=

# --- メール（任意・Resend 無料枠） ---
# 未設定でも申込は保存されます（メールだけ失敗）
# 無料枠では onboarding@resend.dev から「Resend登録メール宛」以外へ送れないことが多いです
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
SIGNUP_NOTIFY_EMAIL=hayanari316@gmail.com

# --- Teams（任意・無料Webhook） ---
TEAMS_WEBHOOK_URL=

# --- 高度な設定（通常不要） ---
# 旧: DISABLE_LEGACY_TENANT_FALLBACK は不要になりました（未所属フォールバック廃止済み）
